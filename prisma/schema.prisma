generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CardStatus {
  NEW
  IN_PROGRESS
  DONE
  PROBLEM
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  passwordHash     String
  createdAt        DateTime @default(now())
  telegramId       BigInt?  @unique
  telegramLinkCode String?  @unique

  cards             Card[]
  pushSubscriptions PushSubscription[]
}

model Card {
  id        String     @id @default(uuid())
  userId    String
  title     String
  link      String?
  status    CardStatus @default(NEW)
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  notes     Note[]
  reminders Reminder[]
}

model Note {
  id        String   @id @default(uuid())
  cardId    String
  text      String
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Reminder {
  id         String    @id @default(uuid())
  cardId     String
  text       String
  remindAt   DateTime
  isSent     Boolean   @default(false)
  isDone     Boolean   @default(false)
  lastSentAt DateTime?
  createdAt  DateTime  @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
